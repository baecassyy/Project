# Gemini API key for SMB relevance filtering (free at aistudio.google.com)
GEMINI_API_KEY=your_key_here

# Product Hunt API key (from https://api.producthunt.com/v2/docs)
PRODUCT_HUNT_API_KEY=your_key_here

# Reddit API credentials (from https://www.reddit.com/prefs/apps)
# Create a "script" type app
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=smb-newsletter-agent/1.0 by u/yourusername
